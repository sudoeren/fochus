generator client {
  provider      = "prisma-client-js"
  engineType    = "library"
  binaryTargets = ["native"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  name      String?
  avatar    String?
  role      String   @default("USER")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  notes           Note[]
  tasks           Task[]
  taskLists       TaskList[]
  pomodoroSessions PomodoroSession[]
  settings        UserSettings?

  @@map("users")
}

model SystemSettings {
  id                String   @id @default(cuid())
  allowRegistration Boolean  @default(true)
  updatedAt         DateTime @updatedAt

  @@map("system_settings")
}

model UserSettings {
  id       String @id @default(cuid())
  userId   String @unique
  theme    String @default("system")
  language String @default("tr")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

model Note {
  id        String    @id @default(cuid())
  title     String
  content   String    @default("")
  isPinned  Boolean   @default(false)
  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  linkedTasks Task[] @relation("NoteToTask")

  @@index([userId])
  @@index([isDeleted])
  @@map("notes")
}

model TaskList {
  id          String   @id @default(cuid())
  title       String
  description String?
  color       String   @default("#3B82F6")
  order       Int      @default(0)
  isDeleted   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  tasks Task[]

  @@index([userId])
  @@map("task_lists")
}

model Task {
  id          String    @id @default(cuid())
  title       String
  description String?
  status      String    @default("PENDING")
  dueDate     DateTime?
  isCompleted Boolean   @default(false)
  isPinned    Boolean   @default(false)
  isDeleted   Boolean   @default(false)
  deletedAt   DateTime?
  order       Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  hasReminder       Boolean   @default(false)
  reminderAt        DateTime?
  isRecurring       Boolean   @default(false)
  recurringType     String?
  recurringInterval Int?
  recurringDays     String?
  lastCompleted     DateTime?
  nextDue           DateTime?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  listId String?
  list   TaskList? @relation(fields: [listId], references: [id], onDelete: SetNull)

  linkedNoteId String?
  linkedNote   Note?   @relation("NoteToTask", fields: [linkedNoteId], references: [id], onDelete: SetNull)

  parentId  String?
  parent    Task?   @relation("SubTask", fields: [parentId], references: [id], onDelete: Cascade)
  subtasks  Task[]  @relation("SubTask")

  @@index([userId])
  @@index([listId])
  @@index([parentId])
  @@index([isDeleted])
  @@index([isCompleted])
  @@map("tasks")
}

model PomodoroSession {
  id        String   @id @default(cuid())
  startTime DateTime
  endTime   DateTime
  duration  Int
  mode      String
  completed Boolean  @default(false)
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([startTime])
  @@map("pomodoro_sessions")
}
