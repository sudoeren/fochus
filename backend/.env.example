# ═══════════════════════════════════════════════════
# Backend — Development only
# ═══════════════════════════════════════════════════
# This file is ONLY needed when running the backend
# directly via `npm run dev` (without Docker).
#
# When using Docker Compose, all environment
# variables are injected from the root .env file.
# You do NOT need this file for Docker setup.
# ═══════════════════════════════════════════════════

# Database
DATABASE_URL="postgresql://fokus:fokus_password@localhost:5432/fokus_db?schema=public"

# JWT
JWT_SECRET="your-super-secret-jwt-key"
JWT_EXPIRES_IN="7d"

# Security
ALLOW_REGISTRATION=true

# CORS
CORS_ORIGIN="http://localhost:3000"
# Google OAuth
GOOGLE_CLIENT_ID=""
