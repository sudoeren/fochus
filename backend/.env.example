# Database
DATABASE_URL="postgresql://fokus:fokus_password@localhost:5432/fokus_db?schema=public"

# JWT
JWT_SECRET="your-super-secret-jwt-key"
JWT_EXPIRES_IN="7d"

# Security
# Set to 'false' to disable new user registration
ALLOW_REGISTRATION=true

# CORS
CORS_ORIGIN="http://localhost:3000"
# Google OAuth
GOOGLE_CLIENT_ID=""
